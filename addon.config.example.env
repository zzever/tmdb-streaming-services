# ─────────────────────────────────────────────────────────────
# TMDB Streaming ES — Addon Configuration
# Copia este fichero como .env y rellena tus valores.
# ─────────────────────────────────────────────────────────────

# ── TMDB API ─────────────────────────────────────────────────
# Obligatorio. Obtén tu API key en https://www.themoviedb.org/settings/api
TMDB_API_KEY=tu_clave_api_aqui

# ── JustWatch (opcional) ──────────────────────────────────────
# Si no se configura, se usan los enlaces genéricos de TMDB.
# No se necesita clave de API — JustWatch se consulta vía su
# GraphQL público igual que hace la web.
# (Sin variable — el acceso es automático si el servidor tiene internet)

# ── Servidor ─────────────────────────────────────────────────
# Puerto en el que escucha el servidor API.
# Por defecto: 8080. En Replit se asigna automáticamente por PORT.
PORT=8080

# ── País por defecto ─────────────────────────────────────────
# Código ISO 3166-1 alpha-2 del país para los proveedores de streaming.
# El addon Stremio siempre usa ES; la web permite cambiar el país en la UI.
DEFAULT_COUNTRY=ES

# ── URL pública del addon (producción) ───────────────────────
# Solo necesaria para generar el manifest.json en producción self-hosted.
# En Replit se detecta automáticamente desde los headers x-forwarded-host.
# Ejemplo: https://tmdb-streaming.tu-dominio.com
PUBLIC_API_URL=

# ── Logging ──────────────────────────────────────────────────
# Nivel de log: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ── Node env ─────────────────────────────────────────────────
NODE_ENV=production

# ─────────────────────────────────────────────────────────────
# INSTALACIÓN DEL ADDON EN STREMIO
# ─────────────────────────────────────────────────────────────
#
# Manifest URL (sustituye HOST por tu URL pública):
#   https://HOST/api/stremio/manifest.json
#
# Para instalar desde Stremio Desktop o Web:
#   stremio://HOST/api/stremio/manifest.json
#
# Catálogos incluidos (v2.4.0):
#   🇪🇸 Películas Populares en España   (movie / popular-es)
#   🇪🇸 Series Populares en España      (series / popular-es)
#   🗾 Anime en España                   (series / anime-es)
#   📺 Programas y Docs en España       (series / programas-es)
#
# Recursos:
#   • stream  → URLs directas a Netflix, Prime, Disney+, Crunchyroll, etc.
#   • meta    → Metadatos enriquecidos desde TMDB
#   • catalog → Listas curadas de populares, anime y programas
# ─────────────────────────────────────────────────────────────
